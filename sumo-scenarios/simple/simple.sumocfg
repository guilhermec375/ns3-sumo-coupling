<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <input>
        <net-file value="simple.net.xml"/>
        <route-files value="simple.rou.xml"/>
    </input>
    <time>
        <begin value="0"/>
        <end value="1000"/>
        <step-length value="0.1"/>
    </time>
    <report>
        <no-step-log value="false"/>
        <verbose value="true"/>
    </report>
</configuration>